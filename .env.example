# AI_PROVIDER: Pilih provider AI — "gemini" (default), "openrouter", atau "zen"
AI_PROVIDER="gemini"

# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GEMINI_MODEL: Model yang digunakan (default: gemini-2.5-flash)
GEMINI_MODEL="gemini-2.5-flash"

# OPENROUTER_API_KEY: Required when AI_PROVIDER="openrouter"
# OPENROUTER_API_KEY="sk-or-v1-..."

# OPENROUTER_MODEL: Model OpenRouter (default: opencode/big-pickle)
# OPENROUTER_MODEL="opencode/big-pickle"

# ZEN_API_KEY: Required when AI_PROVIDER="zen"
# Dapatkan API key di https://opencode.ai/auth
# ZEN_API_KEY="zen-..."

# ZEN_MODEL: Model OpenCode Zen (default: big-pickle)
# ZEN_MODEL="big-pickle"

# IG_USERNAME & IG_PASSWORD: Instagram credentials for instagrapi
# IG_USERNAME="your_instagram_username"
# IG_PASSWORD="your_instagram_password"

# IG_SESSIONID: Alternative to username/password (from browser cookies)
# IG_SESSIONID="your_sessionid"

# GITHUB_TOKEN: Optional, increases GitHub API rate limit to 5000 req/hr
# GITHUB_TOKEN="your_github_token"
